{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "hrtf_version": { "type": "string" },
        "scenario": {
            "type": "object",
            "required": ["name", "robot"],
            "properties": {
                "name": { "type": "string" },
                "description": { "type": "string" },
                "robot": {
                    "type": "object",
                    "required": ["model"],
                    "properties": {
                        "model": { "type": "string" }
                    }
                },
                "simulator": { "type": "object" },
                "initial_conditions": { "type": "object" },
                "duration": { "type": "number" },
                "assertions": { "type": "array" }
            }
        }
    },
    "required": ["scenario"]
}
