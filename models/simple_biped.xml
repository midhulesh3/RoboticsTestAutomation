<mujoco model="simple_biped">
  <compiler angle="radian"/>

  <asset>
    <texture type="2d" name="groundplane" builtin="checker" rgb1="0.2 0.3 0.4" rgb2="0.1 0.15 0.2" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texrepeat="5 5" reflectance="0.2"/>
  </asset>

  <worldbody>
    <light directional="true" diffuse="0.8 0.8 0.8" specular="0.3 0.3 0.3" pos="0 0 5" dir="0 0 -1"/>
    <geom name="floor" type="plane" size="10 10 0.1" material="groundplane" condim="3" friction="1.0 0.005 0.0001"/>

    <body name="base_link" pos="0 0 1.0">
      <freejoint name="floating_base"/>
      <inertial mass="10.0" pos="0 0 0" diaginertia="0.1 0.1 0.05"/>
      <geom type="box" size="0.15 0.1 0.2" rgba="0.3 0.5 0.8 1"/>

      <!-- Left leg -->
      <body name="left_upper_leg" pos="0 0.1 -0.2">
        <joint name="left_hip_pitch" type="hinge" axis="0 1 0" range="-1.57 1.57"/>
        <inertial mass="3.0" pos="0 0 -0.2" diaginertia="0.02 0.02 0.005"/>
        <geom type="capsule" fromto="0 0 0 0 0 -0.4" size="0.05" rgba="0.4 0.6 0.4 1"/>

        <body name="left_lower_leg" pos="0 0 -0.4">
          <joint name="left_knee" type="hinge" axis="0 1 0" range="0 2.5"/>
          <inertial mass="2.0" pos="0 0 -0.2" diaginertia="0.01 0.01 0.003"/>
          <geom type="capsule" fromto="0 0 0 0 0 -0.4" size="0.04" rgba="0.4 0.6 0.4 1"/>

          <body name="left_foot" pos="0 0 -0.4">
            <joint name="left_ankle" type="hinge" axis="0 1 0" range="-0.8 0.8"/>
            <inertial mass="0.5" pos="0.05 0 0" diaginertia="0.001 0.002 0.001"/>
            <geom type="box" size="0.1 0.04 0.02" pos="0.05 0 0" rgba="0.6 0.3 0.3 1"/>
          </body>
        </body>
      </body>

      <!-- Right leg -->
      <body name="right_upper_leg" pos="0 -0.1 -0.2">
        <joint name="right_hip_pitch" type="hinge" axis="0 1 0" range="-1.57 1.57"/>
        <inertial mass="3.0" pos="0 0 -0.2" diaginertia="0.02 0.02 0.005"/>
        <geom type="capsule" fromto="0 0 0 0 0 -0.4" size="0.05" rgba="0.4 0.6 0.4 1"/>

        <body name="right_lower_leg" pos="0 0 -0.4">
          <joint name="right_knee" type="hinge" axis="0 1 0" range="0 2.5"/>
          <inertial mass="2.0" pos="0 0 -0.2" diaginertia="0.01 0.01 0.003"/>
          <geom type="capsule" fromto="0 0 0 0 0 -0.4" size="0.04" rgba="0.4 0.6 0.4 1"/>

          <body name="right_foot" pos="0 0 -0.4">
            <joint name="right_ankle" type="hinge" axis="0 1 0" range="-0.8 0.8"/>
            <inertial mass="0.5" pos="0.05 0 0" diaginertia="0.001 0.002 0.001"/>
            <geom type="box" size="0.1 0.04 0.02" pos="0.05 0 0" rgba="0.6 0.3 0.3 1"/>
          </body>
        </body>
      </body>
    </body>
  </worldbody>
</mujoco>
