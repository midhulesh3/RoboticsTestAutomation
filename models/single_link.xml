<mujoco model="single_link_robot">
  <compiler angle="radian"/>

  <asset>
    <texture type="2d" name="groundplane" builtin="checker" rgb1="0.2 0.3 0.4" rgb2="0.1 0.15 0.2" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texrepeat="5 5"/>
  </asset>

  <worldbody>
    <light directional="true" diffuse="0.8 0.8 0.8" pos="0 0 5" dir="0 0 -1"/>
    <geom name="floor" type="plane" size="10 10 0.1" material="groundplane" condim="3" friction="1.0 0.005 0.0001"/>

    <body name="base_link" pos="0 0 2.0">
      <freejoint name="floating_base"/>
      <inertial mass="5.0" pos="0 0 0" diaginertia="0.05 0.05 0.05"/>
      <geom type="box" size="0.15 0.15 0.15" rgba="0.8 0.3 0.3 1"/>
    </body>
  </worldbody>
</mujoco>
