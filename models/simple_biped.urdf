<robot name="simple_biped">
  <!-- World link for floating base -->
  <link name="world"/>

  <!-- Torso (base link) -->
  <link name="base_link">
    <inertial>
      <mass value="10.0"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.05"/>
    </inertial>
    <visual>
      <geometry><box size="0.3 0.2 0.4"/></geometry>
    </visual>
    <collision>
      <geometry><box size="0.3 0.2 0.4"/></geometry>
    </collision>
  </link>

  <joint name="floating_base" type="floating">
    <parent link="world"/>
    <child link="base_link"/>
  </joint>

  <!-- Left upper leg -->
  <link name="left_upper_leg">
    <inertial>
      <mass value="3.0"/>
      <origin xyz="0 0 -0.2"/>
      <inertia ixx="0.02" ixy="0" ixz="0" iyy="0.02" iyz="0" izz="0.005"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.2"/>
      <geometry><cylinder radius="0.05" length="0.4"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 -0.2"/>
      <geometry><cylinder radius="0.05" length="0.4"/></geometry>
    </collision>
  </link>

  <joint name="left_hip_pitch" type="revolute">
    <parent link="base_link"/>
    <child link="left_upper_leg"/>
    <origin xyz="0 0.1 -0.2"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="100" velocity="5"/>
  </joint>

  <!-- Left lower leg -->
  <link name="left_lower_leg">
    <inertial>
      <mass value="2.0"/>
      <origin xyz="0 0 -0.2"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.003"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.2"/>
      <geometry><cylinder radius="0.04" length="0.4"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 -0.2"/>
      <geometry><cylinder radius="0.04" length="0.4"/></geometry>
    </collision>
  </link>

  <joint name="left_knee" type="revolute">
    <parent link="left_upper_leg"/>
    <child link="left_lower_leg"/>
    <origin xyz="0 0 -0.4"/>
    <axis xyz="0 1 0"/>
    <limit lower="0" upper="2.5" effort="80" velocity="5"/>
  </joint>

  <!-- Left foot -->
  <link name="left_foot">
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0.05 0 0"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="0.05 0 0"/>
      <geometry><box size="0.2 0.08 0.04"/></geometry>
    </visual>
    <collision>
      <origin xyz="0.05 0 0"/>
      <geometry><box size="0.2 0.08 0.04"/></geometry>
    </collision>
  </link>

  <joint name="left_ankle" type="revolute">
    <parent link="left_lower_leg"/>
    <child link="left_foot"/>
    <origin xyz="0 0 -0.4"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.8" upper="0.8" effort="50" velocity="3"/>
  </joint>

  <!-- Right upper leg -->
  <link name="right_upper_leg">
    <inertial>
      <mass value="3.0"/>
      <origin xyz="0 0 -0.2"/>
      <inertia ixx="0.02" ixy="0" ixz="0" iyy="0.02" iyz="0" izz="0.005"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.2"/>
      <geometry><cylinder radius="0.05" length="0.4"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 -0.2"/>
      <geometry><cylinder radius="0.05" length="0.4"/></geometry>
    </collision>
  </link>

  <joint name="right_hip_pitch" type="revolute">
    <parent link="base_link"/>
    <child link="right_upper_leg"/>
    <origin xyz="0 -0.1 -0.2"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="100" velocity="5"/>
  </joint>

  <!-- Right lower leg -->
  <link name="right_lower_leg">
    <inertial>
      <mass value="2.0"/>
      <origin xyz="0 0 -0.2"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.003"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.2"/>
      <geometry><cylinder radius="0.04" length="0.4"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 -0.2"/>
      <geometry><cylinder radius="0.04" length="0.4"/></geometry>
    </collision>
  </link>

  <joint name="right_knee" type="revolute">
    <parent link="right_upper_leg"/>
    <child link="right_lower_leg"/>
    <origin xyz="0 0 -0.4"/>
    <axis xyz="0 1 0"/>
    <limit lower="0" upper="2.5" effort="80" velocity="5"/>
  </joint>

  <!-- Right foot -->
  <link name="right_foot">
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0.05 0 0"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="0.05 0 0"/>
      <geometry><box size="0.2 0.08 0.04"/></geometry>
    </visual>
    <collision>
      <origin xyz="0.05 0 0"/>
      <geometry><box size="0.2 0.08 0.04"/></geometry>
    </collision>
  </link>

  <joint name="right_ankle" type="revolute">
    <parent link="right_lower_leg"/>
    <child link="right_foot"/>
    <origin xyz="0 0 -0.4"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.8" upper="0.8" effort="50" velocity="3"/>
  </joint>
</robot>
